# Discord
DISCORD_BOT_TOKEN=PASTE_DISCORD_BOT_TOKEN_HERE

# Azure App Registration
AZURE_TENANT_ID=PASTE_TENANT_ID_HERE
AZURE_CLIENT_ID=PASTE_CLIENT_ID_HERE
AZURE_CLIENT_SECRET=PASTE_NEW_CLIENT_SECRET_HERE
AZURE_SUBSCRIPTION_ID=PASTE_SUBSCRIPTION_ID_HERE

# Target VM
AZURE_RESOURCE_GROUP=PASTE_RESOURCE_GROUP_HERE
AZURE_VM_NAME=PASTE_VM_NAME_HERE

# Optional access control: allow only this Discord user ID to run commands
# DISCORD_ADMIN_USER_ID=123456789012345678

# Pterodactyl Panel
# Example: https://panel.example.com
PTERODACTYL_PANEL_URL=PASTE_PANEL_URL_HERE

# API key from Pterodactyl panel.
# For start controls through /api/client endpoints, a client key (ptlc_) is usually required.
PTERODACTYL_API_KEY=PASTE_PTERODACTYL_KEY_HERE
